<Window x:Class="CyberSecurityChatBot.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CyberSecurityChatBot.ViewModels"
        xmlns:local="clr-namespace:CyberSecurityChatBot.Views"
        Title="🛡️ CyberSecurity Awareness Chatbot — ST10471194"
        Height="750" Width="1100"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource DarkBgBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas">

    <Window.DataContext>
        <vm:ChatViewModel/>
    </Window.DataContext>

    <!-- Converters must live here so they are resolved BEFORE InitializeComponent parses bindings -->
    <Window.Resources>
        <local:BoolToVisibilityConverter  x:Key="BoolToVisibilityConverter"/>
        <local:BoolToInvisConverter       x:Key="BoolToInvisConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ HEADER ════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0F1524"
                BorderBrush="{StaticResource AccentCyanBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="🛡️" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                                   Foreground="{StaticResource AccentCyanBrush}"
                                   FontSize="16" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="Department of Cybersecurity — South Africa"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreenBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="ONLINE" Foreground="{StaticResource AccentGreenBrush}"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ BODY ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT SIDEBAR ──────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,16">
                        <TextBlock Text="QUICK TOPICS" Foreground="{StaticResource AccentCyanBrush}"
                                   FontSize="11" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,12"/>

                        <Button Content="🔐 Passwords"         Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="Tell me about password safety"          Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="🎣 Phishing"          Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="What is phishing and how do I avoid it?" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="⚠️ Scams"             Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="Tell me about online scams"             Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="🛡️ Privacy"          Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="I'm interested in privacy"              Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="🦠 Malware"           Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="How do I protect against malware?"      Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="📶 Wi-Fi Safety"      Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="Tell me about wifi safety"              Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="🌐 Browsing"          Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="Give me safe browsing tips"             Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="🔑 Two-Factor Auth"   Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="Tell me about 2fa"                      Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="🧠 Social Engineering" Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="What is social engineering?"           Margin="0,0,0,6" HorizontalAlignment="Stretch"/>

                        <Separator Background="{StaticResource BorderBrush2}" Margin="0,12"/>
                        <TextBlock Text="CONVERSATION" Foreground="{StaticResource AccentCyanBrush}"
                                   FontSize="11" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,12"/>

                        <Button Content="💬 How are you?"    Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="How are you?"              Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="❓ What can I ask?" Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="What can I ask you about?" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="🔄 Another tip"     Style="{StaticResource CyberButtonStyle}" Command="{Binding QuickTopicCommand}" CommandParameter="Give me another tip"       Margin="0,0,0,6" HorizontalAlignment="Stretch"/>

                        <Separator Background="{StaticResource BorderBrush2}" Margin="0,12"/>
                        <Button Content="🗑️ Clear Chat" Style="{StaticResource CyberButtonStyle}"
                                Command="{Binding ClearCommand}"
                                Foreground="{StaticResource AccentOrangeBrush}"
                                BorderBrush="{StaticResource AccentOrangeBrush}"
                                Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─── CENTRE: Chat Area ─────────────────────────────────────── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource DarkBgBrush}"
                              Padding="16,12">
                    <ItemsControl ItemsSource="{Binding Messages}" HorizontalAlignment="Stretch">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- USER bubble (right) -->
                                    <Border Grid.Column="1"
                                            Visibility="{Binding IsFromUser, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="{StaticResource UserBubbleBrush}"
                                            BorderBrush="#1E3A6B" BorderThickness="1"
                                            CornerRadius="8,8,2,8"
                                            MaxWidth="480" Padding="12,8" Margin="60,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SenderName}"
                                                       Foreground="{StaticResource AccentCyanBrush}"
                                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Content}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- BOT bubble (left) -->
                                    <Border Grid.Column="0"
                                            Visibility="{Binding IsFromUser, Converter={StaticResource BoolToInvisConverter}}"
                                            Background="{StaticResource BotBubbleBrush}"
                                            BorderBrush="#1E2D45" BorderThickness="1"
                                            CornerRadius="8,8,8,2"
                                            MaxWidth="520" Padding="12,8" Margin="0,0,60,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="🛡️ " FontSize="12"/>
                                                <TextBlock Text="{Binding SenderName}"
                                                           Foreground="{StaticResource AccentGreenBrush}"
                                                           FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Content}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="13" TextWrapping="Wrap" FontFamily="Consolas"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Input Bar -->
                <Border Grid.Row="1" Background="{StaticResource PanelBgBrush}"
                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0"
                        Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 x:Name="InputBox"
                                 Style="{StaticResource ChatInputStyle}"
                                 Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 VerticalAlignment="Center">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SendCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1"
                                Style="{StaticResource SendButtonStyle}"
                                Command="{Binding SendCommand}"
                                Margin="8,0,0,0" Width="80"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─── RIGHT SIDEBAR: Memory Panel ──────────────────────────── -->
            <Border Grid.Column="2" Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1,0,0,0">
                <StackPanel Margin="14,16">
                    <TextBlock Text="🧠 MEMORY" Foreground="{StaticResource AccentCyanBrush}"
                               FontSize="11" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBgBrush}"
                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                            CornerRadius="4" Padding="10,8">
                        <TextBlock Text="{Binding MemoryDisplay}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="12" FontFamily="Consolas" TextWrapping="Wrap"/>
                    </Border>

                    <Separator Background="{StaticResource BorderBrush2}" Margin="0,16"/>
                    <TextBlock Text="💡 PRO TIPS" Foreground="{StaticResource AccentCyanBrush}"
                               FontSize="11" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,8"/>

                    <Border Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                        <TextBlock TextWrapping="Wrap" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Foreground="{StaticResource AccentGreenBrush}">↩ Enter</Run><Run> to send</Run>
                        </TextBlock>
                    </Border>
                    <Border Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                        <TextBlock TextWrapping="Wrap" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}">
                            Say <Run Foreground="{StaticResource AccentCyanBrush}">"tell me more"</Run> for another tip on the same topic.
                        </TextBlock>
                    </Border>
                    <Border Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                        <TextBlock TextWrapping="Wrap" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}">
                            Say <Run Foreground="{StaticResource AccentCyanBrush}">"I'm interested in privacy"</Run> to personalise your tips.
                        </TextBlock>
                    </Border>

                    <Separator Background="{StaticResource BorderBrush2}" Margin="0,16"/>
                    <TextBlock Text="💭 SENTIMENT DETECTION" Foreground="{StaticResource AccentCyanBrush}"
                               FontSize="11" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" CornerRadius="4" Padding="10,8">
                        <StackPanel>
                            <TextBlock FontSize="11" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,4">I detect these moods and adjust my responses:</TextBlock>
                            <TextBlock Text="😰 Worried / Anxious"   FontSize="11" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                            <TextBlock Text="😤 Frustrated / Angry"  FontSize="11" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                            <TextBlock Text="🌟 Curious / Interested" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                            <TextBlock Text="🤔 Confused / Lost"     FontSize="11" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                            <TextBlock Text="😊 Happy / Thankful"    FontSize="11" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        </StackPanel>
                    </Border>

                    <Separator Background="{StaticResource BorderBrush2}" Margin="0,16"/>
                    <TextBlock Text="ℹ️ ABOUT" Foreground="{StaticResource AccentCyanBrush}"
                               FontSize="11" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" CornerRadius="4" Padding="10,8">
                        <TextBlock FontSize="10" FontFamily="Consolas" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Foreground="{StaticResource AccentCyanBrush}">Student:</Run><Run> Thandolwethu Masilela</Run>
                            <LineBreak/>
                            <Run Foreground="{StaticResource AccentCyanBrush}">Student #:</Run><Run> ST10471194</Run>
                            <LineBreak/>
                            <Run Foreground="{StaticResource AccentCyanBrush}">Module:</Run><Run> PROG6221 Part 2</Run>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════ STATUS BAR ════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#090D17"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="16,0"/>
                <TextBlock Grid.Column="1"
                           Text="PROG6221 | PROGRAMMING 2A | Part 2 — WPF GUI"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,16,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
